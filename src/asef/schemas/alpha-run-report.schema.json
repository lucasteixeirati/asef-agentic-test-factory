{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lucasteixeirati/asef-agentic-test-factory/schemas/alpha-run-report-1.0.0.json",
  "title": "ASEF AlphaRunReport 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "asef_version",
    "run_id",
    "workflow_id",
    "workflow_version",
    "status",
    "classification",
    "terminal",
    "execution_mode",
    "language_profile",
    "support_level",
    "context_snapshot_ref",
    "report_generated_from_state_schema",
    "requirement",
    "traceability_nodes",
    "traceability_links",
    "artifacts",
    "attempts",
    "functional_result",
    "quality",
    "human_interventions",
    "policy_and_budgets",
    "usage",
    "evidence",
    "facts",
    "inferences",
    "recommendations",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "report_id": { "$ref": "#/$defs/safeId" },
    "asef_version": { "$ref": "#/$defs/safeId" },
    "run_id": { "$ref": "#/$defs/safeId" },
    "workflow_id": { "$ref": "#/$defs/safeId" },
    "workflow_version": { "$ref": "#/$defs/safeId" },
    "status": {
      "enum": [
        "RECEIVED", "VALIDATING_CONTEXT", "RESOLVING_CONTEXT", "VALIDATING_INPUT",
        "INSPECTING_SUT", "ANALYZING_REQUIREMENT", "WAITING_FOR_CLARIFICATION",
        "ANALYZING_RISK", "DESIGNING_SCENARIOS", "GENERATING_TESTS",
        "CORRECTING_TESTS", "STATIC_VALIDATION", "EXECUTING_TESTS",
        "EVALUATING_EVIDENCE", "WAITING_FOR_HUMAN_REVIEW", "GENERATING_REPORT",
        "SUCCEEDED", "FAILED", "CANCELLED", "POLICY_BLOCKED", "BUDGET_EXHAUSTED"
      ]
    },
    "classification": {
      "enum": [
        "UNCLASSIFIED", "ACCEPTED", "INPUT_ERROR", "CONTEXT_ERROR", "WAITING_HUMAN",
        "TEST_FAILURE", "TEST_ERROR", "SUT_DEFECT_SUSPECTED", "POLICY_VIOLATION",
        "BUDGET_ERROR", "PROVIDER_ERROR", "INFRASTRUCTURE_ERROR", "CANCELLED_BY_USER",
        "INCONCLUSIVE"
      ]
    },
    "terminal": { "type": "boolean" },
    "execution_mode": { "enum": ["demo", "live"] },
    "language_profile": { "$ref": "#/$defs/safeId" },
    "support_level": { "enum": ["reference", "supported", "experimental", "planned"] },
    "context_snapshot_ref": { "$ref": "#/$defs/relativePath" },
    "report_generated_from_state_schema": { "$ref": "#/$defs/safeId" },
    "requirement": { "$ref": "#/$defs/requirement" },
    "traceability_nodes": {
      "type": "array", "minItems": 1, "maxItems": 500,
      "items": { "$ref": "#/$defs/traceNode" }
    },
    "traceability_links": {
      "type": "array", "maxItems": 500,
      "items": { "$ref": "#/$defs/traceLink" }
    },
    "artifacts": {
      "type": "array", "maxItems": 500,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "attempts": {
      "type": "array", "maxItems": 500,
      "items": { "$ref": "#/$defs/attempt" }
    },
    "functional_result": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/functionalResult" }]
    },
    "quality": {
      "type": "array", "maxItems": 500,
      "items": { "$ref": "#/$defs/qualityObservation" }
    },
    "human_interventions": {
      "type": "array", "maxItems": 500,
      "items": { "$ref": "#/$defs/humanIntervention" }
    },
    "policy_and_budgets": { "$ref": "#/$defs/policyAndBudgets" },
    "usage": { "$ref": "#/$defs/usage" },
    "evidence": {
      "type": "array", "minItems": 1, "maxItems": 500,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "facts": {
      "type": "array", "minItems": 1, "maxItems": 500,
      "items": { "$ref": "#/$defs/fact" }
    },
    "inferences": {
      "type": "array", "minItems": 1, "maxItems": 500,
      "items": { "$ref": "#/$defs/inference" }
    },
    "recommendations": {
      "type": "array", "maxItems": 500,
      "items": { "$ref": "#/$defs/recommendation" }
    },
    "limitations": {
      "type": "array", "minItems": 1, "maxItems": 500,
      "items": { "$ref": "#/$defs/limitation" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["SUCCEEDED", "FAILED", "CANCELLED", "POLICY_BLOCKED", "BUDGET_EXHAUSTED"] } } },
      "then": { "properties": { "terminal": { "const": true } } },
      "else": { "properties": { "terminal": { "const": false } } }
    },
    {
      "if": { "properties": { "status": { "const": "SUCCEEDED" } } },
      "then": {
        "properties": {
          "classification": { "const": "ACCEPTED" },
          "functional_result": { "$ref": "#/$defs/functionalResult" },
          "artifacts": { "minItems": 1 },
          "attempts": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "safeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "traceId": {
      "type": "string",
      "pattern": "^(?:(?:REQ|BEH|RSK|SCN)-[0-9]{3}|ART-ATTEMPT-[0-9]{3}|EXEC-ATTEMPT-[0-9]{3}-(?:generated|oracle))$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,63}$"
    },
    "publicText": {
      "type": "string", "minLength": 1, "maxLength": 2000
    },
    "sha256": {
      "type": "string", "pattern": "^[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))[^/]+(?:/[^/]+)*$"
    },
    "idArray": {
      "type": "array", "maxItems": 500, "uniqueItems": true,
      "items": { "$ref": "#/$defs/safeId" }
    },
    "requiredIdArray": {
      "type": "array", "minItems": 1, "maxItems": 500, "uniqueItems": true,
      "items": { "$ref": "#/$defs/safeId" }
    },
    "codeArray": {
      "type": "array", "maxItems": 500, "uniqueItems": true,
      "items": { "$ref": "#/$defs/code" }
    },
    "requirement": {
      "type": "object", "additionalProperties": false,
      "required": ["requirement_id", "title", "description"],
      "properties": {
        "requirement_id": { "const": "REQ-001" },
        "title": { "$ref": "#/$defs/publicText" },
        "description": { "$ref": "#/$defs/publicText" }
      }
    },
    "traceNode": {
      "type": "object", "additionalProperties": false,
      "required": ["node_id", "kind", "statement", "evidence_ids"],
      "properties": {
        "node_id": { "$ref": "#/$defs/traceId" },
        "kind": { "enum": ["REQUIREMENT", "BEHAVIOR", "RISK", "SCENARIO", "ARTIFACT", "EXECUTION"] },
        "statement": { "$ref": "#/$defs/publicText" },
        "evidence_ids": { "$ref": "#/$defs/idArray" }
      }
    },
    "traceLink": {
      "type": "object", "additionalProperties": false,
      "required": ["source_id", "target_id", "kind"],
      "properties": {
        "source_id": { "$ref": "#/$defs/traceId" },
        "target_id": { "$ref": "#/$defs/traceId" },
        "kind": { "enum": ["DERIVED_FROM_REQUIREMENT", "COVERS_SCENARIO", "EXECUTES_ARTIFACT"] }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "relative_path", "sha256", "scenario_ids", "attempt", "evidence_ids"],
      "properties": {
        "artifact_id": { "type": "string", "pattern": "^ART-ATTEMPT-[0-9]{3}$" },
        "relative_path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "scenario_ids": {
          "type": "array", "minItems": 1, "maxItems": 500, "uniqueItems": true,
          "items": { "type": "string", "pattern": "^SCN-[0-9]{3}$" }
        },
        "attempt": { "type": "integer", "minimum": 1 },
        "evidence_ids": { "$ref": "#/$defs/requiredIdArray" }
      }
    },
    "attempt": {
      "type": "object", "additionalProperties": false,
      "required": ["attempt", "artifact_id", "generated_execution_id", "oracle_execution_id", "outcome", "evidence_ids"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "artifact_id": { "type": "string", "pattern": "^ART-ATTEMPT-[0-9]{3}$" },
        "generated_execution_id": { "type": "string", "pattern": "^EXEC-ATTEMPT-[0-9]{3}-generated$" },
        "oracle_execution_id": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^EXEC-ATTEMPT-[0-9]{3}-oracle$" }
          ]
        },
        "outcome": { "$ref": "#/$defs/code" },
        "evidence_ids": { "$ref": "#/$defs/requiredIdArray" }
      }
    },
    "functionalResult": {
      "type": "object", "additionalProperties": false,
      "required": ["accepted", "conclusion_code", "tests", "passed", "failed", "errors", "skipped", "inference_ids", "evidence_ids"],
      "properties": {
        "accepted": { "type": "boolean" },
        "conclusion_code": { "$ref": "#/$defs/code" },
        "tests": { "$ref": "#/$defs/nullableCount" },
        "passed": { "$ref": "#/$defs/nullableCount" },
        "failed": { "$ref": "#/$defs/nullableCount" },
        "errors": { "$ref": "#/$defs/nullableCount" },
        "skipped": { "$ref": "#/$defs/nullableCount" },
        "inference_ids": { "$ref": "#/$defs/requiredIdArray" },
        "evidence_ids": { "$ref": "#/$defs/requiredIdArray" }
      },
      "allOf": [
        {
          "if": { "properties": { "accepted": { "const": true } } },
          "then": {
            "properties": {
              "tests": { "type": "integer", "minimum": 1 },
              "passed": { "type": "integer", "minimum": 1 },
              "failed": { "const": 0 },
              "errors": { "const": 0 },
              "skipped": { "const": 0 }
            }
          }
        }
      ]
    },
    "nullableCount": {
      "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }]
    },
    "qualityObservation": {
      "type": "object", "additionalProperties": false,
      "required": ["capability", "status", "complete", "fact_ids", "evidence_ids", "limitation_codes"],
      "properties": {
        "capability": { "$ref": "#/$defs/safeId" },
        "status": { "enum": ["COMPLETED", "PARTIAL", "UNAVAILABLE", "FAILED", "BUDGET_EXHAUSTED", "NOT_REQUESTED"] },
        "complete": { "type": "boolean" },
        "fact_ids": { "$ref": "#/$defs/idArray" },
        "evidence_ids": { "$ref": "#/$defs/idArray" },
        "limitation_codes": { "$ref": "#/$defs/codeArray" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "COMPLETED" } } },
          "then": {
            "properties": {
              "complete": { "const": true },
              "fact_ids": { "minItems": 1 },
              "evidence_ids": { "minItems": 1 }
            }
          },
          "else": {
            "properties": {
              "complete": { "const": false },
              "limitation_codes": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "humanIntervention": {
      "type": "object", "additionalProperties": false,
      "required": ["intervention_id", "kind", "decision_code", "evidence_ids"],
      "properties": {
        "intervention_id": { "$ref": "#/$defs/safeId" },
        "kind": { "$ref": "#/$defs/code" },
        "decision_code": { "$ref": "#/$defs/code" },
        "evidence_ids": { "$ref": "#/$defs/requiredIdArray" }
      }
    },
    "policyAndBudgets": {
      "type": "object", "additionalProperties": false,
      "required": ["max_model_calls", "max_test_corrections", "max_input_tokens", "max_output_tokens", "max_workflow_seconds", "api_budget_brl"],
      "properties": {
        "max_model_calls": { "type": "integer", "minimum": 0 },
        "max_test_corrections": { "type": "integer", "minimum": 0 },
        "max_input_tokens": { "type": "integer", "minimum": 0 },
        "max_output_tokens": { "type": "integer", "minimum": 0 },
        "max_workflow_seconds": { "type": "integer", "minimum": 0 },
        "api_budget_brl": { "type": "number", "minimum": 0 }
      }
    },
    "usage": {
      "type": "object", "additionalProperties": false,
      "required": ["model_calls", "provider_retries", "test_corrections", "input_tokens", "output_tokens", "elapsed_ms", "estimated_cost_brl"],
      "properties": {
        "model_calls": { "type": "integer", "minimum": 0 },
        "provider_retries": { "type": "integer", "minimum": 0 },
        "test_corrections": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "estimated_cost_brl": { "type": "number", "minimum": 0 }
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "kind", "relative_path", "sha256", "schema_version", "integrity_status", "publishable", "sanitized"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/safeId" },
        "kind": { "$ref": "#/$defs/publicText" },
        "relative_path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "schema_version": { "$ref": "#/$defs/publicText" },
        "integrity_status": { "enum": ["VERIFIED", "MISSING", "MISMATCH", "NOT_CHECKED"] },
        "publishable": { "type": "boolean" },
        "sanitized": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "publishable": { "const": true } } },
          "then": {
            "properties": {
              "sanitized": { "const": true },
              "integrity_status": { "const": "VERIFIED" }
            }
          }
        }
      ]
    },
    "fact": {
      "type": "object", "additionalProperties": false,
      "required": ["fact_id", "category", "statement_code", "value", "source_kind", "observation_status", "source_ref", "evidence_ids"],
      "properties": {
        "fact_id": { "$ref": "#/$defs/safeId" },
        "category": { "enum": ["REQUIREMENT", "ANALYSIS", "ARTIFACT", "EXECUTION", "ORACLE", "QUALITY", "HUMAN", "POLICY", "BUDGET", "USAGE", "INTEGRITY"] },
        "statement_code": { "$ref": "#/$defs/code" },
        "value": { "type": ["string", "integer", "number", "boolean", "null"], "maxLength": 2000 },
        "source_kind": { "enum": ["REQUEST", "STATE", "SNAPSHOT", "MANIFEST", "EXECUTION", "EVALUATION", "QUALITY", "HUMAN_DECISION", "RUNTIME"] },
        "observation_status": { "enum": ["OBSERVED", "NOT_OBSERVED", "NOT_APPLICABLE"] },
        "source_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/relativePath" }] },
        "evidence_ids": { "$ref": "#/$defs/idArray" }
      },
      "allOf": [
        {
          "if": { "properties": { "observation_status": { "enum": ["NOT_OBSERVED", "NOT_APPLICABLE"] } } },
          "then": { "properties": { "value": { "type": "null" } } }
        },
        {
          "if": { "properties": { "observation_status": { "const": "OBSERVED" } } },
          "then": { "properties": { "value": { "not": { "type": "null" } } } }
        }
      ]
    },
    "inference": {
      "type": "object", "additionalProperties": false,
      "required": ["inference_id", "kind", "conclusion_code", "statement", "basis_fact_ids", "evidence_ids", "uncertainty"],
      "properties": {
        "inference_id": { "$ref": "#/$defs/safeId" },
        "kind": { "enum": ["CLASSIFICATION", "FUNCTIONAL_RESULT", "QUALITY_INTERPRETATION", "EVIDENCE_INTEGRITY", "READINESS"] },
        "conclusion_code": { "$ref": "#/$defs/code" },
        "statement": { "$ref": "#/$defs/publicText" },
        "basis_fact_ids": { "$ref": "#/$defs/requiredIdArray" },
        "evidence_ids": { "$ref": "#/$defs/requiredIdArray" },
        "uncertainty": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/publicText" }] }
      }
    },
    "recommendation": {
      "type": "object", "additionalProperties": false,
      "required": ["recommendation_id", "recommendation_code", "applies_to", "statement", "blocking", "related_inference_ids", "limitation_codes"],
      "properties": {
        "recommendation_id": { "$ref": "#/$defs/safeId" },
        "recommendation_code": { "enum": ["REVIEW_SUT_DEFECT", "REVIEW_GENERATED_TEST", "RUN_ASEF_DOCTOR", "REVIEW_POLICY", "REVIEW_BUDGET", "PROVIDE_CLARIFICATION", "INSPECT_EVIDENCE", "DO_NOT_USE_IN_PRODUCTION"] },
        "applies_to": { "$ref": "#/$defs/safeId" },
        "statement": { "$ref": "#/$defs/publicText" },
        "blocking": { "type": "boolean" },
        "related_inference_ids": { "$ref": "#/$defs/idArray" },
        "limitation_codes": { "$ref": "#/$defs/codeArray" }
      },
      "anyOf": [
        { "properties": { "related_inference_ids": { "minItems": 1 } } },
        { "properties": { "limitation_codes": { "minItems": 1 } } }
      ]
    },
    "limitation": {
      "type": "object", "additionalProperties": false,
      "required": ["limitation_code", "severity", "statement"],
      "properties": {
        "limitation_code": { "$ref": "#/$defs/code" },
        "severity": { "enum": ["INFO", "WARNING", "BLOCKING"] },
        "statement": { "$ref": "#/$defs/publicText" }
      }
    }
  }
}
